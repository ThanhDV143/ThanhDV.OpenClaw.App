{
  "id": "gym-assistant",
  "name": "Gym Assistant",
  "description": "Query and append to a Google Sheets workout journal.",
  "version": "0.1.0",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": [
      "gym_alias_list",
      "gym_alias_add",
      "gym_log_latest",
      "gym_log_search",
      "gym_log_append"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "spreadsheetId": {
        "type": "string",
        "description": "Google Sheet spreadsheet ID."
      },
      "sheetName": {
        "type": "string",
        "description": "Workout sheet/tab name."
      },
      "credentialsPath": {
        "type": "string",
        "description": "Path to Google service account JSON."
      },
      "defaultRestSeconds": {
        "type": "number",
        "description": "Default rest time when the user does not specify it."
      },
      "aliasStorePath": {
        "type": "string",
        "description": "Path to persistent exercise alias memory JSON."
      }
    }
  }
}
